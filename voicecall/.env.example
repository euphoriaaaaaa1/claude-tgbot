# 电话模块环境变量。复制为 .env（已 gitignore）后填写。真实值绝不进仓库。

# CALL_TOKEN：来电端点(订阅/触发/开关) + 通话记录/备注读写端点的共享密钥。
#   fail-closed：未设或空 → 这些端点恒 401。通话记录含 NSFW 全文，读端点也必须凭它（防 tailnet 无凭证读走）。
#   生成：python3 -c "import secrets;print(secrets.token_urlsafe(32))"
#   前端不硬编码：首次开"来电通知"或首次看通话记录时弹框输入一次，存浏览器 localStorage。
CALL_TOKEN=

# VAPID 密钥对（Web Push 用；不做来电推送可不管）。私钥绝不进仓库。
#   生成：python3 -c "from py_vapid import Vapid01 as V;v=V();v.generate_keys();v.save_key('vapid_private.pem')"
#   公钥导出为 vapid_public.b64（applicationServerKey，前端运行时从 /push/vapid_public 取）。
VAPID_PRIVATE_KEY_FILE=vapid_private.pem
VAPID_PUBLIC_KEY_FILE=vapid_public.b64

# STT/TTS 服务地址（voice-bridge）。默认本机 7788。
VOICE_BRIDGE_URL=http://127.0.0.1:7788

# ffmpeg 路径（留空自动探测 PATH）。
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg

# 绑定地址：默认 127.0.0.1（靠 Tailscale serve 反代）；勿设 0.0.0.0 暴露公网。
HOST=127.0.0.1
