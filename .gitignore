# ── 密钥/凭证：绝不入库 ──
.env
*.env
!*.env.example
# configs/_global.yml 含 DeepSeek key，只提交 _global.example.yml（gitignore 不支持行内注释，注释须独占一行）
configs/_global.yml
**/token*
**/*secret*

# ── 运行时状态/数据 ──
.jiwen-state/
.director-mode/
.self-initiate-state/
**/inbox/
**/chats/
group_transcripts/
*.jsonl
data/
resource/

# ── Python / 系统 ──
__pycache__/
*.pyc
.venv/
venv/
.DS_Store
*.bak
*.bak-*
*.tmp

# ── 各 bot 运行时会长出的私有内容（示例只保留 chenlulu 出厂种子）──
channels/*/memory/*.md
!channels/chenlulu/memory/MEMORY.md

# JS 依赖
node_modules/
