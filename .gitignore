# ── 密钥/凭证：绝不入库 ──
.env
*.env
!*.env.example
# configs/_global.yml 含 DeepSeek key，只提交 _global.example.yml（gitignore 不支持行内注释，注释须独占一行）
configs/_global.yml
**/token*
**/*secret*

# ── 运行时状态/数据 ──
.jiwen-state/
.director-mode/
.self-initiate-state/
**/inbox/
**/chats/
group_transcripts/
*.jsonl
data/
resource/

# ── Python / 系统 ──
__pycache__/
*.pyc
.venv/
venv/
.DS_Store
*.bak
*.bak-*
*.tmp

# ── 各 bot 运行时会长出的私有内容（示例只保留 chenlulu 出厂种子）──
channels/*/memory/*.md
!channels/chenlulu/memory/MEMORY.md

# JS 依赖
node_modules/

# ── 电话模块（voicecall/）私密文件：绝不进仓库 ──
voicecall/.env
voicecall/*.pem
voicecall/vapid_public.b64
voicecall/push_state.json
voicecall/call_aliases.json
voicecall/call_history.json
voicecall/.pytest_cache/
# 内部开发产物：测试套件与流程文档不进公开库（部分文件为字符串比对内联了红线字面量）
voicecall/tests/
voicecall/.devflow/
